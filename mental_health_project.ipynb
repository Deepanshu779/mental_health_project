import streamlit as st
from utils.bot_engine import (
    check_crisis,
    detect_mood,
    get_offline_response,
    generate_ai_response,
    EMERGENCY_RESPONSE
)

def bot_reply(msg):
    mood = detect_mood(msg)
    if check_crisis(msg):
        return EMERGENCY_RESPONSE
    return get_offline_response("🌿 Serene", mood)

